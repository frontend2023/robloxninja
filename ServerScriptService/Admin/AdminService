local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")
local RunService = game:GetService("RunService")

local PlayerStatsConfig = require(ReplicatedStorage:WaitForChild("PlayerStatsConfig"))
local DatabaseFolder = ServerScriptService:WaitForChild("Database")
local PlayerStatsDatabase = require(DatabaseFolder:WaitForChild("PlayerStats"))
local ServerStatsFolder = ServerScriptService:WaitForChild("Stats")
local StatService = require(ServerStatsFolder:WaitForChild("StatService"))

local RemotesFolder = ReplicatedStorage:WaitForChild("Remotes")
local AdminRemotesFolder = RemotesFolder:WaitForChild("Admin")
local AdminOpsEvent = AdminRemotesFolder:WaitForChild("AdminOpsEvent")

local AdminService = {}
local ActiveTokens = {}
local isShuttingDown = false

game:BindToClose(function()
	isShuttingDown = true
end)

local function verifyAdmin(player)
	if RunService:IsStudio() or player.UserId <= 0 or game.CreatorId == player.UserId or PlayerStatsConfig.ADMIN_USER_IDS[player.UserId] then
		print("[ADMIN DEBUG - SERVER] verifyAdmin PASSED untuk player:", player.Name)
		return true
	end
	print("[ADMIN DEBUG - SERVER] verifyAdmin FAILED untuk player:", player.Name, "- Kicking player.")
	player:Kick("[SECURITY] Akses Admin Ilegal.")
	return false
end

local function validateToken(userId, token)
	local data = ActiveTokens[userId]
	if data and data.Token == token and (os.time() - data.Time) < 30 then
		ActiveTokens[userId] = nil
		return true
	end
	ActiveTokens[userId] = nil
	return false
end

AdminOpsEvent.OnServerEvent:Connect(function(player, op, payload)
	print("[ADMIN DEBUG - SERVER] Menerima sinyal OnServerEvent. Op:", tostring(op))
	if isShuttingDown or not verifyAdmin(player) then return end

	if op == "OP_RT_55" then
		local newToken = tostring(math.random(100000, 999999))
		ActiveTokens[player.UserId] = {Token = newToken, Time = os.time()}
		AdminOpsEvent:FireClient(player, true, "TOKEN_GRANTED", newToken)
	
	elseif op == "OP_S_77" then
		local rawQuery = tostring(payload):lower()
		local query = string.match(rawQuery, "^%s*(.-)%s*$") or ""
		print("[ADMIN DEBUG - SERVER] Mencari player dengan query nama:", query)
		
		local foundPlayer = nil
		for _, p in ipairs(Players:GetPlayers()) do
			local pName = p.Name:lower()
			local pDisplayName = p.DisplayName:lower()
			if pName == query or pDisplayName == query then
				foundPlayer = p
				break
			end
		end
		
		if foundPlayer then
			local data = StatService.GetPlayerData(foundPlayer.UserId)
			print("[ADMIN DEBUG - SERVER] Player DITEMUKAN. Nama:", foundPlayer.Name, "Level:", data and data.Level or 1)
			AdminOpsEvent:FireClient(player, true, "Pemain ditemukan!", {
				Name = foundPlayer.Name,
				UserId = foundPlayer.UserId,
				Level = data and data.Level or 1
			})
		else
			print("[ADMIN DEBUG - SERVER] Player TIDAK DITEMUKAN untuk query:", query)
			AdminOpsEvent:FireClient(player, false, "Pemain tidak ditemukan!")
		end
	
	elseif op == "OP_L_88" then
		local targetPlayer = Players:GetPlayerByUserId(tonumber(payload.UserId))
		if targetPlayer then
			StatService.AddLevel(targetPlayer, tonumber(payload.Amount) or 1)
			local data = StatService.GetPlayerData(targetPlayer.UserId)
			AdminOpsEvent:FireClient(player, true, "Level diperbarui.", {
				Name = targetPlayer.Name,
				UserId = targetPlayer.UserId,
				Level = data.Level
			})
		end
	
	elseif op == "OP_P_99" then
		local targetPlayer = Players:GetPlayerByUserId(tonumber(payload.UserId))
		if targetPlayer then
			local data = StatService.GetPlayerData(targetPlayer.UserId)
			if data then
				data.Points = math.max(0, data.Points + (tonumber(payload.Amount) or 0))
				StatService.SyncPlayerData(targetPlayer)
				PlayerStatsDatabase.SaveData(targetPlayer, {
					Level = data.Level,
					Points = data.Points,
					BaseStats = data.BaseStats
				})
				AdminOpsEvent:FireClient(player, true, "Poin diperbarui.", {
					Name = targetPlayer.Name,
					UserId = targetPlayer.UserId,
					Level = data.Level
				})
			end
		end
	
	elseif op == "OP_RP_00" then
		if validateToken(player.UserId, payload.Token) then
			local targetUserId = tonumber(payload.TargetUserId)
			local targetPlayer = Players:GetPlayerByUserId(targetUserId)
			PlayerStatsDatabase.ResetPlayerData(targetUserId)
			
			if targetPlayer then
				StatService.IgnoreSessionSave(targetUserId)
				if RunService:IsStudio() then
					StatService.ReloadPlayerData(targetPlayer)
				else
					targetPlayer:Kick("Data di-reset.")
				end
			end
			AdminOpsEvent:FireClient(player, true, "Database target di-reset.")
		else
			AdminOpsEvent:FireClient(player, false, "Sesi keamanan reset gagal!")
		end
	
	elseif op == "OP_RG_11" then
		if validateToken(player.UserId, payload.Token) then
			StatService.IgnoreAllSessionSaves()
			PlayerStatsDatabase.IncrementGlobalVersion()
			
			if RunService:IsStudio() then
				for _, p in ipairs(Players:GetPlayers()) do
					StatService.ReloadPlayerData(p)
				end
				AdminOpsEvent:FireClient(player, true, "Global Reset selesai [IsStudio].")
			else
				for _, p in ipairs(Players:GetPlayers()) do
					p:Kick("Global Reset [VER_Q].")
				end
			end
		else
			AdminOpsEvent:FireClient(player, false, "Sesi keamanan reset gagal!")
		end
	end
end)

return AdminService