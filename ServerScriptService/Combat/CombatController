local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local PlayerStatsConfig = require(ReplicatedStorage:WaitForChild("PlayerStatsConfig"))
local ModulesFolder = ReplicatedStorage:WaitForChild("Modules")
local CombatFolder = ModulesFolder:WaitForChild("Combat")
local CombatSystem = require(CombatFolder:WaitForChild("CombatSystem"))
local HitSystem = require(CombatFolder:WaitForChild("HitSystem"))

local SecurityFolder = ServerScriptService:WaitForChild("Security")
local CombatSec = require(SecurityFolder:WaitForChild("Combat"))

local ServerStatsFolder = ServerScriptService:WaitForChild("Stats")
local StatService = require(ServerStatsFolder:WaitForChild("StatService"))
local HealthBarService = require(ServerStatsFolder:WaitForChild("HealthBarService"))

-- BOOTLOADER ADMIN SERVICE (MENGAKTIFKAN MODUL SERVER ADMIN)
local AdminFolder = ServerScriptService:WaitForChild("Admin")
local AdminService = require(AdminFolder:WaitForChild("AdminService"))

local RemotesFolder = ReplicatedStorage:WaitForChild("Remotes")
local CombatRemotesFolder = RemotesFolder:WaitForChild("Combat")
local AttackEvent = CombatRemotesFolder:WaitForChild("AttackEvent")
local CombatResultEvent = CombatRemotesFolder:WaitForChild("CombatResultEvent")

local function getNPCObjectStats(humanoid)
	return {Level = 1, DerivedStats = {MaxHP = humanoid.MaxHealth, Defence = PlayerStatsConfig.INITIAL_PLAYER_INFO.Defence, DodgeChance = 0.0}}
end

local function onPlayerAdded(player)
	player.CharacterAdded:Connect(function(character)
		local humanoid = character:WaitForChild("Humanoid", 10)
		if humanoid then
			humanoid.Died:Connect(function()
				HitSystem.ClearTracking(character)
			end)
		end
	end)
end

Players.PlayerAdded:Connect(onPlayerAdded)
for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(onPlayerAdded, player)
end

Players.PlayerRemoving:Connect(function(player)
	CombatSec.ClearCooldownTrack(player.UserId)
	HitSystem.ClearTracking(player)
end)

AttackEvent.OnServerEvent:Connect(function(player, targetChar)
	local attackerChar = player.Character
	if not attackerChar or not targetChar then return end

	local attackerHumanoid = attackerChar:FindFirstChildOfClass("Humanoid")
	local targetHumanoid = targetChar:FindFirstChildOfClass("Humanoid")
	if not attackerHumanoid or not targetHumanoid or attackerHumanoid.Health <= 0 or targetHumanoid.Health <= 0 then return end

	local attackerData = StatService.GetPlayerData(player.UserId)
	if not attackerData then return end

	local isCooldownValid, cooldownErr = CombatSec.ValidateCooldown(player.UserId, attackerData.DerivedStats.AttackSpeed)
	if not isValid then return end

	local targetData = nil
	if Players:GetPlayerFromCharacter(targetChar) then
		local targetPlayer = Players:GetPlayerFromCharacter(targetChar)
		targetData = StatService.GetPlayerData(targetPlayer.UserId)
	else
		targetData = getNPCObjectStats(targetHumanoid)
	end

	if not targetData then return end

	local combatResult = CombatSystem.ResolveAttack(attackerChar, targetChar, attackerData, targetData)

	local targetCurrentHP = 0
	if combatResult.ResultType ~= "MISS" and combatResult.Damage > 0 then
		if Players:GetPlayerFromCharacter(targetChar) then
			targetCurrentHP = HealthBarService.ApplyDamage(Players:GetPlayerFromCharacter(targetChar), combatResult.Damage)
		else
			targetHumanoid.Health = math.max(0, targetHumanoid.Health - combatResult.Damage)
			targetCurrentHP = targetHumanoid.Health
		end
	else
		targetCurrentHP = Players:GetPlayerFromCharacter(targetChar) and HealthBarService.GetHP(Players:GetPlayerFromCharacter(targetChar).UserId) or targetHumanoid.Health
	end

	CombatResultEvent:FireClient(player, combatResult)
	if Players:GetPlayerFromCharacter(targetChar) then
		CombatResultEvent:FireClient(Players:GetPlayerFromCharacter(targetChar), combatResult)
	end

	if targetCurrentHP <= 0 then
		HitSystem.ClearTracking(targetChar)
	end
end)