local Players = game:GetService("Players")
local player = Players.LocalPlayer
local PlayerScripts = player:WaitForChild("PlayerScripts")
local HelperFolder = PlayerScripts:WaitForChild("Helper")
local Theme = require(HelperFolder:WaitForChild("Theme"))
local UIHelper = require(HelperFolder:WaitForChild("UIHelper"))

local PlayerStatsGui = {}

function PlayerStatsGui.Create(characterUi, derivedStatsLayout, baseStatNames)
	local ui = {}

	-- PERLEBAR PANEL KE KANAN (LEBAR 460 PX, TINGGI 310 PX)
	ui.StatPanel = UIHelper.MakeRoundedFrame(characterUi, "StatPanel", UDim2.new(0, 460, 0, 310), UDim2.new(0.5, -230, 0.5, -155), Theme.Colors.Background, Theme.CornerRadius)
	ui.StatPanel.Visible = false

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(45, 45, 45)
	stroke.Thickness = 1
	stroke.Parent = ui.StatPanel

	-- GRADIENT LATAR BELAKANG METALLIK RPG PREMIUM
	local gradient = Instance.new("UIGradient")
	gradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(38, 38, 38)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(18, 18, 18))
	})
	gradient.Rotation = 90
	gradient.Parent = ui.StatPanel

	-- AREA KEPALA IDENTITAS JATI DIRI RPG (AVATAR, RANK, POWER, POINTS)
	ui.AvatarImage = Instance.new("ImageLabel")
	ui.AvatarImage.Name = "AvatarImage"
	ui.AvatarImage.Size = UDim2.new(0, 42, 0, 42)
	ui.AvatarImage.Position = UDim2.new(0, 15, 0, 12)
	ui.AvatarImage.BackgroundColor3 = Theme.Colors.TabBarBg
	ui.AvatarImage.BorderSizePixel = 0
	ui.AvatarImage.Parent = ui.StatPanel

	local avatarCorner = Instance.new("UICorner")
	avatarCorner.CornerRadius = UDim.new(1, 0)
	avatarCorner.Parent = ui.AvatarImage

	local avatarStroke = Instance.new("UIStroke")
	avatarStroke.Color = Color3.fromRGB(60, 60, 60)
	avatarStroke.Thickness = 1
	avatarStroke.Parent = ui.AvatarImage

	ui.NameLabel = Instance.new("TextLabel")
	ui.NameLabel.Name = "NameLabel"
	ui.NameLabel.Size = UDim2.new(0, 130, 0, 16)
	ui.NameLabel.Position = UDim2.new(0, 64, 0, 12)
	ui.NameLabel.BackgroundTransparency = 1
	ui.NameLabel.Font = Theme.FontBold
	ui.NameLabel.TextColor3 = Theme.Colors.TextLight
	ui.NameLabel.TextSize = 11
	ui.NameLabel.TextXAlignment = Enum.TextXAlignment.Left
	ui.NameLabel.TextTruncate = Enum.TextTruncate.AtEnd
	ui.NameLabel.Text = player.DisplayName
	ui.NameLabel.Parent = ui.StatPanel

	ui.ClassLabel = Instance.new("TextLabel")
	ui.ClassLabel.Name = "ClassLabel"
	ui.ClassLabel.Size = UDim2.new(0, 130, 0, 14)
	ui.ClassLabel.Position = UDim2.new(0, 64, 0, 26)
	ui.ClassLabel.BackgroundTransparency = 1
	ui.ClassLabel.Font = Theme.FontRegular
	ui.ClassLabel.TextColor3 = Theme.Colors.TextMuted
	ui.ClassLabel.TextSize = 10
	ui.ClassLabel.TextXAlignment = Enum.TextXAlignment.Left
	ui.ClassLabel.Text = "Class: Shinobi"
	ui.ClassLabel.Parent = ui.StatPanel

	ui.PowerLabel = Instance.new("TextLabel")
	ui.PowerLabel.Name = "PowerLabel"
	ui.PowerLabel.Size = UDim2.new(0, 140, 0, 16)
	ui.PowerLabel.Position = UDim2.new(0, 200, 0, 12)
	ui.PowerLabel.BackgroundTransparency = 1
	ui.PowerLabel.Font = Theme.FontBold
	ui.PowerLabel.TextColor3 = Color3.fromRGB(240, 180, 80) -- Emas
	ui.PowerLabel.TextSize = 11
	ui.PowerLabel.TextXAlignment = Enum.TextXAlignment.Left
	ui.PowerLabel.Text = "POWER: --"
	ui.PowerLabel.Parent = ui.StatPanel

	ui.PointsLabel = Instance.new("TextLabel")
	ui.PointsLabel.Name = "PointsLabel"
	ui.PointsLabel.Size = UDim2.new(0, 140, 0, 14)
	ui.PointsLabel.Position = UDim2.new(0, 200, 0, 26)
	ui.PointsLabel.BackgroundTransparency = 1
	ui.PointsLabel.Font = Theme.FontBold
	ui.PointsLabel.TextColor3 = Theme.Colors.PointGreen
	ui.PointsLabel.TextSize = 11
	ui.PointsLabel.TextXAlignment = Enum.TextXAlignment.Left
	ui.PointsLabel.Text = "Points: 0"
	ui.PointsLabel.Parent = ui.StatPanel

	-- TOMBOL TUTUP MERAH ELEGAN DI POJOK KANAN (TIDAK MUNGKIN MENUMPUK INFORMASI)
	ui.CloseBtn = Instance.new("TextButton")
	ui.CloseBtn.Name = "CloseBtn"
	ui.CloseBtn.Size = UDim2.new(0, 14, 0, 14)
	ui.CloseBtn.Position = UDim2.new(1, -24, 0, 12)
	ui.CloseBtn.BackgroundColor3 = Theme.Colors.Danger
	ui.CloseBtn.Text = ""
	ui.CloseBtn.ZIndex = 5
	ui.CloseBtn.Parent = ui.StatPanel

	local closeCorner = Instance.new("UICorner")
	closeCorner.CornerRadius = UDim.new(1, 0)
	closeCorner.Parent = ui.CloseBtn

	ui.DragHandle = Instance.new("Frame")
	ui.DragHandle.Name = "DragHandle"
	ui.DragHandle.Size = UDim2.new(1, 0, 0, 52)
	ui.DragHandle.BackgroundTransparency = 1
	ui.DragHandle.Parent = ui.StatPanel

	UIHelper.MakeDraggable(ui.StatPanel, ui.DragHandle)

	-- DUA PANEL DISEDIAKAN BERDAMPINGAN SECARA STATIS TANPA SCROLLBAR
	ui.BaseStatsFrame = UIHelper.MakeRoundedFrame(ui.StatPanel, "BaseStatsTab", UDim2.new(0, 210, 0, 195), UDim2.new(0, 15, 0, 60), Theme.Colors.Background, 0)
	ui.StatsInfoFrame = UIHelper.MakeRoundedFrame(ui.StatPanel, "StatsInfoTab", UDim2.new(0, 210, 0, 195), UDim2.new(0, 235, 0, 60), Theme.Colors.Background, 0)
	
	ui.BaseStatsFrame.BackgroundTransparency = 1
	ui.StatsInfoFrame.BackgroundTransparency = 1

	-- TOMBOL RESET STATUS (WARNA REDUP ELEGAN)
	ui.ResetBtn = Instance.new("TextButton")
	ui.ResetBtn.Size = UDim2.new(0, 100, 0, 26)
	ui.ResetBtn.Position = UDim2.new(0, 15, 1, -38)
	ui.ResetBtn.BackgroundColor3 = Color3.fromRGB(60, 35, 35)
	ui.ResetBtn.Font = Theme.FontBold
	ui.ResetBtn.TextColor3 = Color3.fromRGB(240, 100, 100)
	ui.ResetBtn.TextSize = 10
	ui.ResetBtn.Text = "RESET STATUS"
	ui.ResetBtn.Parent = ui.StatPanel

	local resetCorner = Instance.new("UICorner")
	resetCorner.CornerRadius = UDim.new(0, 6)
	resetCorner.Parent = ui.ResetBtn

	local resetStroke = Instance.new("UIStroke")
	resetStroke.Color = Color3.fromRGB(110, 50, 50)
	resetStroke.Thickness = 1
	resetStroke.Parent = ui.ResetBtn

	ui.ApplyBtn = Instance.new("TextButton")
	ui.ApplyBtn.Size = UDim2.new(0, 100, 0, 26)
	ui.ApplyBtn.Position = UDim2.new(1, -115, 1, -38)
	ui.ApplyBtn.BackgroundColor3 = Theme.Colors.Success
	ui.ApplyBtn.Font = Theme.FontBold
	ui.ApplyBtn.TextColor3 = Theme.Colors.TextLight
	ui.ApplyBtn.TextSize = 11
	ui.ApplyBtn.Text = "APPLY"
	ui.ApplyBtn.Visible = false
	ui.ApplyBtn.Parent = ui.StatPanel

	local applyCorner = Instance.new("UICorner")
	applyCorner.CornerRadius = UDim.new(0, 6)
	applyCorner.Parent = ui.ApplyBtn

	ui.StatRows = {}
	for i, stat in ipairs(baseStatNames) do
		local yPos = (i - 1) * 29
		local row = UIHelper.MakeRoundedFrame(ui.BaseStatsFrame, "Row_" .. stat, UDim2.new(1, 0, 0, 25), UDim2.new(0, 0, 0, yPos), Theme.Colors.RowBg, Theme.RowCornerRadius)

		local rowStroke = Instance.new("UIStroke")
		rowStroke.Color = Color3.fromRGB(45, 45, 45)
		rowStroke.Thickness = 1
		rowStroke.Parent = row

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(0.6, 0, 1, 0)
		label.Position = UDim2.new(0, 8, 0, 0)
		label.BackgroundTransparency = 1
		label.Font = Theme.FontRegular
		label.TextColor3 = Theme.Colors.TextLight
		label.TextSize = 11
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Text = stat .. ": --"
		label.Parent = row

		local minusBtn = Instance.new("TextButton")
		minusBtn.Size = UDim2.new(0, 20, 0, 20)
		minusBtn.Position = UDim2.new(1, -44, 0.5, -10)
		minusBtn.BackgroundColor3 = Color3.fromRGB(120, 40, 40)
		minusBtn.Font = Theme.FontBold
		minusBtn.TextColor3 = Theme.Colors.TextLight
		minusBtn.TextSize = 11
		minusBtn.Text = "-"
		minusBtn.Visible = false
		minusBtn.Parent = row

		local minusCorner = Instance.new("UICorner")
		minusCorner.CornerRadius = UDim.new(0, 4)
		minusCorner.Parent = minusBtn

		local plusBtn = Instance.new("TextButton")
		plusBtn.Size = UDim2.new(0, 20, 0, 20)
		plusBtn.Position = UDim2.new(1, -22, 0.5, -10)
		plusBtn.BackgroundColor3 = Theme.Colors.Success
		plusBtn.Font = Theme.FontBold
		plusBtn.TextColor3 = Theme.Colors.TextLight
		plusBtn.TextSize = 11
		plusBtn.Text = "+"
		plusBtn.Visible = false
		plusBtn.Parent = row

		local plusCorner = Instance.new("UICorner")
		plusCorner.CornerRadius = UDim.new(0, 4)
		plusCorner.Parent = plusBtn

		ui.StatRows[stat] = {
			RowObject = row,
			Label = label, 
			PlusButton = plusBtn,
			MinusButton = minusBtn
		}
	end

	ui.InfoRows = {}
	for i, layout in ipairs(derivedStatsLayout) do
		local yPos = (i - 1) * 19.5 -- Pemampatan jarak vertikal pas di area 195px
		local row = Instance.new("Frame")
		row.Name = "Row_" .. layout.Key
		row.Size = UDim2.new(1, 0, 0, 18)
		row.Position = UDim2.new(0, 0, 0, yPos)
		row.BackgroundTransparency = 1
		row.BorderSizePixel = 0
		row.Parent = ui.StatsInfoFrame

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(0.65, 0, 1, 0)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Font = Theme.FontRegular
		nameLabel.TextColor3 = Theme.Colors.TextMuted
		nameLabel.TextSize = 11
		nameLabel.TextXAlignment = Enum.TextXAlignment.Left
		nameLabel.Text = layout.Label
		nameLabel.Parent = row

		local valLabel = Instance.new("TextLabel")
		valLabel.Size = UDim2.new(0.35, 0, 1, 0)
		valLabel.Position = UDim2.new(0.65, 0, 0, 0)
		valLabel.BackgroundTransparency = 1
		valLabel.Font = Theme.FontBold
		valLabel.TextColor3 = layout.Color or Theme.Colors.TextLight
		valLabel.TextSize = 11
		valLabel.TextXAlignment = Enum.TextXAlignment.Right
		valLabel.Text = "--"
		valLabel.Parent = row

		ui.InfoRows[layout.Key] = {
			NameLabel = nameLabel,
			ValueLabel = valLabel,
			Config = layout
		}
	end

	-- PANEL KONFIRMASI PEMBELIAN (DIKONDISIKAN PAS MENUTUPI AREA 460PX)
	ui.ConfirmPanel = UIHelper.MakeRoundedFrame(ui.StatPanel, "ConfirmPanel", UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), Color3.fromRGB(15, 15, 15), Theme.CornerRadius)
	ui.ConfirmPanel.BackgroundTransparency = 0.15
	ui.ConfirmPanel.ZIndex = 10
	ui.ConfirmPanel.Visible = false

	local ConfirmTitle = Instance.new("TextLabel")
	ConfirmTitle.Size = UDim2.new(1, -24, 0, 110)
	ConfirmTitle.Position = UDim2.new(0, 12, 0, 45)
	ConfirmTitle.BackgroundTransparency = 1
	ConfirmTitle.Font = Theme.FontBold
	ConfirmTitle.TextColor3 = Theme.Colors.TextLight
	ConfirmTitle.TextSize = 12
	ConfirmTitle.Text = "RESET ALL STATS?\n\nThis will reset all your stats to default starting values.\n\nCost: 99 Robux"
	ConfirmTitle.TextWrapped = true
	ConfirmTitle.ZIndex = 11
	ConfirmTitle.Parent = ui.ConfirmPanel

	ui.ConfirmCancelBtn = Instance.new("TextButton")
	ui.ConfirmCancelBtn.Size = UDim2.new(0, 100, 0, 30)
	ui.ConfirmCancelBtn.Position = UDim2.new(0.5, -110, 0, 180)
	ui.ConfirmCancelBtn.BackgroundColor3 = Theme.Colors.RowBg
	ui.ConfirmCancelBtn.Font = Theme.FontBold
	ui.ConfirmCancelBtn.TextColor3 = Theme.Colors.TextLight
	ui.ConfirmCancelBtn.TextSize = 11
	ui.ConfirmCancelBtn.Text = "CANCEL"
	ui.ConfirmCancelBtn.ZIndex = 11
	ui.ConfirmCancelBtn.Parent = ui.ConfirmPanel

	local ccCorner = Instance.new("UICorner")
	ccCorner.CornerRadius = UDim.new(0, 6)
	ccCorner.Parent = ui.ConfirmCancelBtn

	ui.ConfirmOkBtn = Instance.new("TextButton")
	ui.ConfirmOkBtn.Size = UDim2.new(0, 100, 0, 30)
	ui.ConfirmOkBtn.Position = UDim2.new(0.5, 10, 0, 180)
	ui.ConfirmOkBtn.BackgroundColor3 = Theme.Colors.Success
	ui.ConfirmOkBtn.Font = Theme.FontBold
	ui.ConfirmOkBtn.TextColor3 = Theme.Colors.TextLight
	ui.ConfirmOkBtn.TextSize = 11
	ui.ConfirmOkBtn.Text = "BUY & RESET"
	ui.ConfirmOkBtn.ZIndex = 11
	ui.ConfirmOkBtn.Parent = ui.ConfirmPanel

	local coCorner = Instance.new("UICorner")
	coCorner.CornerRadius = UDim.new(0, 6)
	coCorner.Parent = ui.ConfirmOkBtn

	return ui
end

return PlayerStatsGui