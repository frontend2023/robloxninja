local function formatValue(val, isPercent)
	if isPercent then
		return string.format("%.2f%%", val * 100)
	else
		if type(val) == "number" then
			return (val % 1 ~= 0) and string.format("%.2f", val) or tostring(math.round(val))
		end
		return tostring(val)
	end
end

-- KALKULASI POWER SCORE SECARA REAL-TIME MEMBERIKAN VISUAL FEEDBACK SENSASIONAL
local function calculatePowerScore(level, baseStats)
	local baseSum = 0
	for _, val in pairs(baseStats) do
		baseSum = baseSum + val
	end
	return (level * 100) + (baseSum * 15)
end

local function updateVisuals()
	if not serverData then return end

	-- Gabungkan data level & display name agar terlihat padat & menonjol
	ui.NameLabel.Text = player.DisplayName .. " (Lv. " .. tostring(serverData.Level) .. ")"
	ui.PointsLabel.Text = "Points: " .. tostring(virtualPoints)

	-- Update kalkulasi Power secara instan setiap kali poin dinaikkan
	local currentStatsSnapshot = {}
	for stat, val in pairs(serverData.BaseStats) do
		currentStatsSnapshot[stat] = val + (pendingAllocations[stat] or 0)
	end
	local powerScore = calculatePowerScore(serverData.Level, currentStatsSnapshot)
	ui.PowerLabel.Text = "POWER: " .. string.format('%,d', powerScore)

	local hasAnyPending = false

	for stat, row in pairs(ui.StatRows) do
		local baseVal = serverData.BaseStats[stat] or 5
		local pendingVal = pendingAllocations[stat] or 0
		local bonusVal = equipmentBonuses[stat] or 0

		local displayText = stat .. ": " .. tostring(baseVal + pendingVal)
		if bonusVal > 0 then
			displayText = displayText .. " (+" .. tostring(bonusVal) .. ")"
		end
		row.Label.Text = displayText

		row.PlusButton.Visible = (virtualPoints > 0 and (baseVal + pendingVal) < PlayerStatsConfig.STAT_CAP)
		row.MinusButton.Visible = (pendingVal > 0)

		-- PENDAPAN GLOWING HIJAU SEGAR SAAT STATUS MENINGKAT (VISUAL FEEDBACK FORUM)
		if pendingVal > 0 then
			hasAnyPending = true
			row.RowObject.BackgroundColor3 = Color3.fromRGB(35, 75, 45) -- Hijau glowing tipis
			row.RowObject:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(80, 180, 100)
		else
			row.RowObject.BackgroundColor3 = Theme.Colors.RowBg
			row.RowObject:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(45, 45, 45)
		end
	end

	ui.ApplyBtn.Visible = hasAnyPending

	for key, row in pairs(ui.InfoRows) do
		local val = serverData.DerivedStats[key] or 0
		if key == "MaxHP" then
			row.ValueLabel.Text = tostring(val)
		else
			row.ValueLabel.Text = formatValue(val, row.Config.IsPercent)
		end
	end
end

for stat, row in pairs(ui.StatRows) do
	row.PlusButton.MouseButton1Click:Connect(function()
		if not serverData then return end
		local baseVal = serverData.BaseStats[stat] or 5
		local pendingVal = pendingAllocations[stat] or 0

		if virtualPoints > 0 and (baseVal + pendingVal) < PlayerStatsConfig.STAT_CAP then
			pendingAllocations[stat] = pendingVal + 1
			virtualPoints = virtualPoints - 1
			updateVisuals()
		end
	end)

	row.MinusButton.MouseButton1Click:Connect(function()
		local pendingVal = pendingAllocations[stat] or 0
		if pendingVal > 0 then
			pendingAllocations[stat] = pendingVal - 1
			virtualPoints = virtualPoints + 1
			updateVisuals()
		end
	end)
end

ui.ApplyBtn.MouseButton1Click:Connect(function()
	local applyData = {}
	local hasData = false
	for stat, val in pairs(pendingAllocations) do
		if val > 0 then
			applyData[stat] = val
			hasData = true
		end
	end

	if hasData then
		AllocateStatRequest:FireServer(applyData)
		for stat, _ in pairs(pendingAllocations) do
			pendingAllocations[stat] = 0
		end
	end
end)

