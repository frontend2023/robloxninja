local function selectTab(tabType)
	if tabType == "BASE" then
		ui.BaseStatsFrame.Visible = true
		ui.StatsInfoFrame.Visible = false
		ui.BaseTabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		ui.InfoTabBtn.TextColor3 = Color3.fromRGB(130, 130, 130)
		TweenService:Create(ui.ActiveIndicator, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, 0, 1, -2)
		}):Play()
	else
		ui.BaseStatsFrame.Visible = false
		ui.StatsInfoFrame.Visible = true
		ui.BaseTabBtn.TextColor3 = Color3.fromRGB(130, 130, 130)
		ui.InfoTabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		TweenService:Create(ui.ActiveIndicator, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0.5, 0, 1, -2)
		}):Play()
	end
end

