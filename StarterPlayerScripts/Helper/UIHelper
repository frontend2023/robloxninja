local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

local UIHelper = {}

local currentHighestOrder = 50
local managedGuis = {}
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

function UIHelper.BringToFront(screenGui)
	if not screenGui or not screenGui:IsA("ScreenGui") then return end
	currentHighestOrder = currentHighestOrder + 1
	screenGui.DisplayOrder = currentHighestOrder
end

function UIHelper.RegisterWindow(screenGui)
	if not screenGui or not screenGui:IsA("ScreenGui") then return end
	managedGuis[screenGui] = true
	UIHelper.BringToFront(screenGui)

	-- EVENT DETEKSI KLIK NATIVE: Otomatis fokus saat bagian mana pun dari Panel diklik
	for _, child in ipairs(screenGui:GetChildren()) do
		if child:IsA("Frame") then
			child.Active = true
			child.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					UIHelper.BringToFront(screenGui)
				end
			end)
		end
	end
end

function UIHelper.MakeDraggable(frame, handle)
	handle = handle or frame

	local dragging = false
	local dragInput
	local mouseStartPos
	local frameStartUDim

	-- SISTEM SENSOR PENYETEL ULANG POSISI DEFAULT (AUTO-CENTER ON REOPEN)
	local originalPosition = frame.Position
	frame:GetPropertyChangedSignal("Visible"):Connect(function()
		if frame.Visible then
			frame.Position = originalPosition
		end
	end)

	local function update(input)
		local delta = input.Position - mouseStartPos
		local viewportSize = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(0, 0)

		local targetXOffset = frameStartUDim.X.Offset + delta.X
		local targetYOffset = frameStartUDim.Y.Offset + delta.Y

		local currentAbsX = (viewportSize.X * frameStartUDim.X.Scale) + targetXOffset
		local currentAbsY = (viewportSize.Y * frameStartUDim.Y.Scale) + targetYOffset

		local maxX = math.max(0, viewportSize.X - frame.AbsoluteSize.X)
		local maxY = math.max(0, viewportSize.Y - frame.AbsoluteSize.Y)

		local clampedAbsX = math.clamp(currentAbsX, 0, maxX)
		local clampedAbsY = math.clamp(currentAbsY, 0, maxY)

		local finalXOffset = clampedAbsX - (viewportSize.X * frameStartUDim.X.Scale)
		local finalYOffset = clampedAbsY - (viewportSize.Y * frameStartUDim.Y.Scale)

		local targetPos = UDim2.new(frameStartUDim.X.Scale, finalXOffset, frameStartUDim.Y.Scale, finalYOffset)
		local tweenInfo = TweenInfo.new(0.07, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		TweenService:Create(frame, tweenInfo, {Position = targetPos}):Play()
	end

	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			local myGui = frame:FindFirstAncestorOfClass("ScreenGui")
			if myGui then
				UIHelper.BringToFront(myGui)
			end

			dragging = true
			mouseStartPos = input.Position
			frameStartUDim = frame.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	handle.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			update(input)
		end
	end)
end

function UIHelper.GetOrCreateScreenGui(name)
	local gui = playerGui:FindFirstChild(name)
	if not gui then
		gui = Instance.new("ScreenGui")
		gui.Name = name
		gui.ResetOnSpawn = false
		gui.IgnoreGuiInset = true
		gui.Parent = playerGui
	end
	return gui
end

function UIHelper.MakeRoundedFrame(parent, name, size, pos, bgCol, radius)
	local frame = Instance.new("Frame")
	frame.Name = name
	frame.Size = size
	frame.Position = pos
	frame.BackgroundColor3 = bgCol
	frame.BorderSizePixel = 0
	frame.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius)
	corner.Parent = frame
	return frame
end

return UIHelper